{
  "name": "xlsb-parser",
  "version": "0.2.0",
  "description": "Browser-based XLSB (Excel Binary Workbook) parser. Pure JS, no native addons.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:browser": "esbuild src/index.ts --bundle --outfile=public/bundle.js --format=esm",
    "test": "vitest run",
    "dev": "node server.mjs",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "xlsb",
    "excel",
    "binary",
    "workbook",
    "parser",
    "browser",
    "xlsx"
  ],
  "license": "GPL-3.0",
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
